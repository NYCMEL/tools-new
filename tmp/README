RUN THIS COMMAND TO CREATE CERTIFICATES:

sudo certbot certonly --apache \
  -d melify.com \
  -d www.melify.com \
  -d twitter.melify.com \
  -d emphora.melify.com \
  -d dropbox.melify.com \
  -d wc.melify.com \
  -d bookmarker.melify.com



REPLACE MELIFY.SSL.CONF FILE WITH THESE:

/etc/letsencrypt/live/melify.com/fullchain.pem
/etc/letsencrypt/live/melify.com/privkey.pem
